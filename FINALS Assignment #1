# Operations
# Perform the following:

# List:
list = ['wash face', 'brush teeth',
        'eat breakfast', 'use computer', 'play games']
print(list)
# Add 1 new item
list.append('read a book')
# Remove 1 item
list.remove('wash face')
# Sort the list
list.sort()
print('Updated Daily Tasks:', list)

# Tuple:
